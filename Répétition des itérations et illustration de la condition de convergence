legend({'atanh(2^{-k})','Somme cumulée','Répétitions'},'FontSize',10,'Location','northeast');
grid on;

subplot(1,2,2);
% Simulation : erreur résiduelle avec et sans répétitions
z0_test = 0.9;  % angle proche de la limite
k_max = 18;
err_no_rep = zeros(1, k_max);
err_with_rep = zeros(1, k_max);

for k = 1:k_max
    t1 = cordic_tanh_no_repeat(z0_test, k);
    t2 = cordic_tanh(z0_test, k);
    err_no_rep(k)   = abs(tanh(z0_test) - t1);
    err_with_rep(k) = abs(tanh(z0_test) - t2);
end

semilogy(1:k_max, err_no_rep,   'r-o', 'LineWidth',2,'MarkerSize',5, ...
         'DisplayName','Sans répétition'); hold on;
semilogy(1:k_max, err_with_rep, 'b-s', 'LineWidth',2,'MarkerSize',5, ...
         'DisplayName','Avec répétition');
