% Itérations à répéter (séquence k_{i+1} = 3k_i + 1)
repeat_iters = [4, 13, 40];  % jusqu'à k=20

subplot(1,2,1);
stem(k_vals, atanh_k, 'b', 'LineWidth',2,'MarkerFaceColor','b'); hold on;
stem(k_vals, cumsum_atanh, 'r--', 'LineWidth',1.5,'MarkerFaceColor','r');
